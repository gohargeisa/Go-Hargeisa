# --- Supabase (required) ---
# Find these in your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # server-only, never expose to the client

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://gohargeisa.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-KMCLGC9Q2S

# --- Maps (optional) ---
# The site uses OpenStreetMap tiles by default (no key required). If you
# switch to Google Maps, add your key here and update components/map/*.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Email (optional, for newsletter / contact form delivery) ---
RESEND_API_KEY=
